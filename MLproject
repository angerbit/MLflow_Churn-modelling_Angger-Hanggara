name: churn_model_project
conda_env: conda.yaml
entry_points:
  main:
    parameters:
      dataset_path: {type: str, default: "namadataset_preprocessing"}
      target_column: {type: str, default: "Exited"}
      test_size: {type: float, default: 0.2}
      random_state: {type: int, default: 42}
      max_iter: {type: int, default: 1000}
      mlflow_experiment_name: {type: str, default: "churn_modeling"}
      tracking_uri: {type: str, default: "http://127.0.0.1:5000"}
      x_data_path: {type: str, default: ""}
      y_data_path: {type: str, default: ""}
    command: >
      python modelling.py
        --dataset-path {dataset_path}
        --target-column {target_column}
        --test-size {test_size}
        --random-state {random_state}
        --max-iter {max_iter}
        --experiment-name {mlflow_experiment_name}
        --tracking-uri {tracking_uri}
        --x-data-path {x_data_path}
        --y-data-path {y_data_path}
