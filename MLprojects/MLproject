name: churn_modeling

conda_env: conda.yaml

entry_points:
  main:
    command: "python modelling.py
      --x-data-path {x-data-path}
      --y-data-path {y-data-path}
      --test-size {test-size}
      --random-state {random-state}
      --max-iter {max-iter}
      --experiment-name {experiment-name}"
    parameters:
      x-data-path:
        description: "Path to X preprocessed CSV file"
        type: string
        default: "X_preprocessed.csv"
      y-data-path:
        description: "Path to y preprocessed CSV file"
        type: string
        default: "y_preprocessed.csv"
      test-size:
        description: "Test set size (0-1)"
        type: float
        default: 0.2
      random-state:
        description: "Random state for reproducibility"
        type: int
        default: 42
      max-iter:
        description: "Maximum iterations for SVC"
        type: int
        default: 1000
      experiment-name:
        description: "MLflow experiment name"
        type: string
        default: "churn_modeling"
